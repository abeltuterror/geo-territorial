generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Vendedor {
  id             Int          @id @default(autoincrement())
  codigo         Int          @unique
  nombreCompleto String       @map("nombre_completo")
  territorios    Territorio[]

  @@map("vendedores")
}

model PuntoVenta {
  id            String      @id
  nombreCliente String      @map("nombre_cliente")
  ultimaCompra  DateTime?   @map("ultima_compra")
  longitud      Float
  latitud       Float
  montoAnual    Float?      @map("monto_anual")
  moneda        String      @default("S/")
  territorioId  String?     @map("territorio_id")
  territorio    Territorio? @relation(fields: [territorioId], references: [id])

  @@index([longitud, latitud])
  @@map("puntos_venta")
}

model Territorio {
  id          String       @id @default(cuid())
  nombre      String
  color       String
  vendedorId  Int          @map("vendedor_id")
  vendedor    Vendedor     @relation(fields: [vendedorId], references: [id])
  geoJson     Json         @map("geo_json")
  puntosVenta PuntoVenta[]
  creadoEn    DateTime     @default(now()) @map("creado_en")

  @@map("territorios")
}
